{# Shared macros used across card.html.j2, knowledge_tree.html.j2, and history.html.j2. #}

{% macro step(step, file_path) %}
{% set dot = "✓" if step.status == "done" else ("~" if step.status == "progress" else ("—" if step.status == "abandoned" else "")) %}
<div class="step {{ step.status }}" data-file="{{ file_path }}" data-line="{{ step.line }}">
  <span class="drag-handle" data-step-handle>⠿</span>
  <span class="status-dot status-{{ step.status }}"
    onmousedown="event.stopPropagation();event.preventDefault()"
    data-action="cycle-step" data-file-path="{{ file_path }}">{{ dot }}</span>
  <span class="text"
    onmousedown="event.stopPropagation()"
    data-action="start-edit-text" data-stop="1">{{ step.text }}</span>
  <button class="remove-btn"
    onmousedown="event.stopPropagation();event.preventDefault()"
    data-action="remove-step" data-file-path="{{ file_path }}">×</button>
</div>
{% endmacro %}


{% macro group(heading, items, file_path) %}
{% set done = items | selectattr('status', 'equalto', 'done') | list | length %}
{% set total = items | length %}
{% set all_done = total > 0 and done == total %}
<div class="sec-group">
  <div class="sec-heading{% if not all_done %} open{% endif %}" data-action="toggle-section">
    {{ heading }} <span class="sec-count">({{ done }}/{{ total }})</span>
  </div>
  <div class="sec-items" style="display:{% if all_done %}none{% else %}block{% endif %}">
    {% for it in items %}{{ step(it, file_path) }}{% endfor %}
    <div class="add-row">
      <input type="text" placeholder="Add task…"
        data-add-step-input
        data-file-path="{{ file_path }}" data-heading="{{ heading }}">
      <button data-action="add-step"
        data-file-path="{{ file_path }}" data-heading="{{ heading }}">+</button>
    </div>
  </div>
</div>
{% endmacro %}


{% macro file_entry(n) %}
{% set label = n.name[:-3] if n.name[-3:] == '.md' else n.name %}
<div class="note-item" data-kind="{{ n.kind | default('md') }}"
  data-action="open-note-preview"
  data-path="{{ n.path }}" data-title="{{ n.name }}">{{ label }}</div>
{% endmacro %}


{% macro subdir_group(group_, item_slug, readme_rel) %}
{% set key = item_slug ~ '/' ~ group_.rel_dir %}
<details class="notes-group" data-subdir-key="{{ key }}">
  <summary class="notes-group-heading">
    <span class="notes-chevron" aria-hidden="true">&#9656;</span>
    <span class="notes-group-name">{{ group_.label }}/</span>
    <span class="notes-count">({{ group_ | subtree_count }})</span>
    {% if readme_rel %}
    <button class="notes-new-btn" title="New note in this folder"
      data-action="create-note-for" data-stop="1" data-prevent="1"
      data-readme-rel="{{ readme_rel }}" data-rel-dir="{{ group_.rel_dir }}">+</button>
    <button class="notes-upload-btn" title="Upload files into this folder"
      data-action="upload-to-notes" data-stop="1" data-prevent="1"
      data-readme-rel="{{ readme_rel }}" data-rel-dir="{{ group_.rel_dir }}">↑</button>
    <button class="notes-mkdir-btn" title="New subdirectory inside this folder"
      data-action="create-notes-subdir" data-stop="1" data-prevent="1"
      data-readme-rel="{{ readme_rel }}" data-rel-dir="{{ group_.rel_dir }}">+ folder</button>
    {% endif %}
  </summary>
  <div class="notes-list">
    {% for f in group_.files %}{{ file_entry(f) }}{% endfor %}
    {% for g in group_.groups %}{{ subdir_group(g, item_slug, readme_rel) }}{% endfor %}
  </div>
</details>
{% endmacro %}


{% macro files_block(tree, readme_rel, item_slug, total) %}
<div class="notes-block{% if total == 0 %} is-empty{% endif %}">
  <div class="notes-heading">
    Files <span class="notes-count">({{ total }})</span>
    {% if readme_rel %}
    <button class="notes-mkdir-btn"
      title="New folder at the item root (sibling of notes/)"
      data-action="create-notes-subdir" data-stop="1" data-prevent="1"
      data-readme-rel="{{ readme_rel }}" data-rel-dir="">+ folder</button>
    {% endif %}
  </div>
  <div class="notes-list">
    {% for f in tree.files %}{{ file_entry(f) }}{% endfor %}
    {% for g in tree.groups %}{{ subdir_group(g, item_slug, readme_rel) }}{% endfor %}
  </div>
</div>
{% endmacro %}


{% macro readme_link(item) %}
<div class="readme-preview"
  data-action="open-note-preview"
  data-path="{{ item.path }}" data-title="{{ item.title }}">≡ README</div>
{% endmacro %}


{% macro deliverables_block(deliverables) %}
{% if deliverables %}
<div class="deliverables">
  <div class="dlv-heading">Deliverables</div>
  {% for d in deliverables %}
  <div class="dlv-item">
    <a class="dlv-link" href="#"
      data-action="open-deliverable" data-stop="1" data-prevent="1"
      data-full-path="{{ d.full_path }}"
      {% if d.desc %}title="{{ d.desc }}"{% endif %}>⤓ {{ d.label }}</a>{% if d.desc %} <span class="dlv-desc">— {{ d.desc }}</span>{% endif %}
  </div>
  {% endfor %}
</div>
{% endif %}
{% endmacro %}


{% macro card_actions(item, icons) %}
{% set rel_dir = (item.path | dirname) ~ '/' %}
{% set work_title = 'Work on — insert "work on ' ~ item.slug ~ '" in the focused terminal tab' %}
<div class="card-actions">
  <button class="git-action-btn card-action-work-on"
    title="{{ work_title }}" aria-label="{{ work_title }}"
    data-action="work-on" data-slug="{{ item.slug }}">{{ icons.work_on | safe }}</button>
  <button class="git-action-btn card-action-folder"
    title="Open folder in file manager" aria-label="Open folder in file manager"
    data-action="open-folder" data-rel-dir="{{ rel_dir }}">{{ icons.folder | safe }}</button>
</div>
{% endmacro %}


{% macro index_badge(idx, top_level=false) %}
<a class="knowledge-index-badge{% if top_level %} knowledge-index-top{% endif %}"
  data-action="open-note-preview" data-stop="1"
  data-path="{{ idx.path }}" data-title="{{ idx.title }}"
  title="{{ idx.path }}">index</a>
{% endmacro %}


{% macro open_folder_btn(rel_path, label) %}
{# data-prevent stops the surrounding <summary> from toggling and the
   parent .knowledge-card from triggering open-note-preview when the
   user clicks the open-folder affordance. #}
<button type="button" class="knowledge-open-folder"
  title="Open {{ rel_path }} in file manager"
  aria-label="Open {{ label }} folder in file manager"
  data-action="open-folder" data-stop="1" data-prevent="1"
  data-rel-dir="{{ rel_path }}">{{ icons.folder | safe }}</button>
{% endmacro %}


{% macro knowledge_card(e) %}
{% set parent_dir = e.path | dirname %}
<div class="knowledge-card" data-node-id="{{ e.path }}"
  data-action="open-note-preview"
  data-path="{{ e.path }}" data-title="{{ e.title }}">
  <div class="knowledge-title">{{ e.title }}</div>
  {{ open_folder_btn(parent_dir, e.title) }}
  {% if e.desc %}<div class="knowledge-desc">{{ e.desc }}</div>{% endif %}
  <div class="knowledge-path">{{ e.path }}</div>
</div>
{% endmacro %}


{% macro knowledge_group(node) %}
<details class="knowledge-group" data-node-id="{{ node.rel_dir }}">
  <summary class="knowledge-group-heading">
    <span class="knowledge-chevron" aria-hidden="true">&#9656;</span>
    <span class="knowledge-group-name">{{ node.label }}</span>
    <span class="knowledge-count">{{ node.count }} {% if node.count == 1 %}note{% else %}notes{% endif %}</span>
    {% if node.index %}{{ index_badge(node.index, top_level=false) }}{% endif %}
    <span class="knowledge-heading-spacer"></span>
    {{ open_folder_btn(node.rel_dir, node.label) }}
  </summary>
  {% if node.body %}
  <div class="knowledge-list">
    {% for e in node.body %}{{ knowledge_card(e) }}{% endfor %}
  </div>
  {% endif %}
  {% for child in node.children %}{{ knowledge_group(child) }}{% endfor %}
</details>
{% endmacro %}

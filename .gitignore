# Node — frontend build toolchain. esbuild is invoked via `npx --yes` by
# `make frontend` so `node_modules/` is never required, but a developer who
# runs `npm install` locally (for IDE completions) produces one.
node_modules/
.npm-cache/
npm-debug.log*

# Frontend build output — rebuilt in CI by the `frontend` job in
# .github/workflows/release.yml and passed to the per-OS bundle jobs as
# an artifact. Run `make frontend` locally before `cargo tauri build`.
frontend/dist/

# MkDocs build output (built in CI, deployed via GitHub Actions)
site/

# Local-only environment file — per-developer overrides read by the dev
# scripts. The repo's shipped values are safe defaults; the local copy is
# where credentials or machine-specific paths go.
.env

# Editors / OS
.idea/
.vscode/
*.swp
.DS_Store

# Claude local scratch
.claude/*
!.claude/skills/
!.claude/scripts/

# Rust / Tauri build output (src-tauri/.gitignore handles its own tree,
# this catches target/ anywhere else a Rust crate lands in the repo).
/target/
